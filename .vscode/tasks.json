{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build: CMake Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build/Debug"
      ],
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Flash: OpenOCD program ELF",
      "type": "shell",
      "command": "C:/Users/Lenovo/scoop/shims/openocd.exe",
      "args": [
        "-s",
        "C:/Users/Lenovo/scoop/apps/openocd/0.12.0/share/openocd/scripts",
        "-f",
        "interface/stlink.cfg",
        "-f",
        "target/stm32f1x.cfg",
        "-c",
        "adapter speed 1000",
        "-c",
        "program D:/PWMADC/build/Debug/PWMADC.elf verify reset exit"
      ],
      "dependsOn": "Build: CMake Debug",
      "problemMatcher": [],
      "group": {
        "kind": "test",
        "isDefault": true
      }
    }
  ]
}
